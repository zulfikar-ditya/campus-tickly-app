# Copy this file to `.env` and adjust for your setup, then run with:
#   flutter run --dart-define-from-file=.env
#
# Read in code via AppConfig (String.fromEnvironment). If omitted, AppConfig
# falls back to a per-platform default (Android emulator -> 10.0.2.2, else
# localhost).

# Base URL of the Tickly backend API.
#   Android emulator        -> http://10.0.2.2:3000
#   iOS simulator / desktop -> http://localhost:3000
#   Physical device         -> http://<your-LAN-IP>:3000
API_BASE_URL=http://10.0.2.2:3000
