{
	"name": "clean-elysia",
	"version": "1.0.0",
	"author": {
		"name": "Aolus Software"
	},
	"type": "module",
	"private": true,
	"scripts": {
		"dev": "bun run --hot --watch ./src/index.ts",
		"start": "bun run ./dist/server/index.js",
		"build": "bun build \t--target bun \t--minify-whitespace \t--minify-syntax \t--outfile ./dist/index.js \tsrc/index.ts",
		"build:binary": "bun build \t--compile \t--minify-whitespace \t--minify-syntax \t--target bun \t--outfile server \tsrc/index.ts",
		"lint": "bun run eslint . --ext .ts,.js",
		"lint:fix": "bun run eslint . --ext .ts,.js --fix",
		"format": "bun run prettier --write .",
		"prepare": "husky install",
		"db:generate": "bunx drizzle-kit generate",
		"db:migrate": "bunx drizzle-kit migrate",
		"db:push": "bunx drizzle-kit push",
		"db:pull": "bunx drizzle-kit introspect",
		"db:studio": "bunx drizzle-kit studio",
		"db:drop": "bunx drizzle-kit drop",
		"db:seed": "bun run ./src/libs/database/postgres/seed/index.ts",
		"db:postgres:seed": "bun run ./src/libs/database/postgres/seed/index.ts",
		"db:clickhouse:migrate": "bun run ./src/libs/database/clickhouse/scripts/migrate.ts migrate",
		"db:clickhouse:status": "bun run ./src/libs/database/clickhouse/scripts/migrate.ts status",
		"i18n:keys": "bun run ./src/libs/i18n/scripts/generate-keys.ts",
		"typecheck": "bun run tsc --noEmit"
	},
	"dependencies": {
		"@bogeychan/elysia-logger": "^0.1.10",
		"@clickhouse/client": "^1.18.4",
		"@elysiajs/bearer": "^1.4.4",
		"@elysiajs/cors": "^1.4.2",
		"@elysiajs/jwt": "^1.4.2",
		"@elysiajs/openapi": "^1.4.15",
		"bcryptjs": "^3.0.3",
		"bullmq": "^5.76.8",
		"crypto-js": "^4.2.0",
		"dayjs": "^1.11.20",
		"dotenv": "^17.4.2",
		"drizzle-orm": "^0.45.2",
		"drizzle-seed": "^0.3.1",
		"elysia": "^1.4.28",
		"elysia-helmet": "^3.1.0",
		"elysia-rate-limit": "^4.6.2",
		"envalid": "^8.1.1",
		"nodemailer": "^8.0.7",
		"pg": "^8.20.0",
		"pino": "^10.3.1",
		"pino-pretty": "^13.1.3"
	},
	"devDependencies": {
		"@eslint/js": "^10.0.1",
		"@types/bcrypt": "^6.0.0",
		"@types/bun": "^1.3.14",
		"@types/crypto-js": "^4.2.2",
		"@types/node": "^25.7.0",
		"@types/nodemailer": "^8.0.0",
		"@types/pg": "^8.20.0",
		"@typescript-eslint/eslint-plugin": "^8.59.3",
		"@typescript-eslint/parser": "^8.59.3",
		"bun-types": "^1.3.14",
		"drizzle-kit": "^0.31.10",
		"eslint": "^10.3.0",
		"eslint-config-prettier": "^10.1.8",
		"eslint-plugin-import": "^2.32.0",
		"eslint-plugin-prettier": "^5.5.5",
		"eslint-plugin-simple-import-sort": "^13.0.0",
		"globals": "^17.6.0",
		"husky": "^9.1.7",
		"lint-staged": "^17.0.4",
		"tsx": "^4.21.0",
		"typescript-eslint": "^8.59.3"
	},
	"peerDependencies": {
		"typescript": "^6.0.3"
	},
	"lint-staged": {
		"*.ts": [
			"bun run lint:fix",
			"bun run format"
		]
	}
}
