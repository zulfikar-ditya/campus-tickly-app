NODE_ENV=development

APP_NAME=Elysia APP
APP_PORT=3000
APP_URL=http://localhost:3000
APP_TIMEZONE=UTC
APP_KEY=your-app-key
APP_JWT_SECRET=your-jwt-secret

APP_CLUSTER_MODE=false
APP_CLUSTER_WORKERS=0

# Reuse-port: run N processes on the same port (kernel load-balances).
# Alternative to cluster mode — do NOT enable both. Scale via PM2 instances.
APP_REUSE_PORT=false

# With docker compose, use service hostnames instead of localhost:
#   postgres / redis / clickhouse (e.g. @postgres:5432, REDIS_HOST=redis)
# NOTE: keep values UNQUOTED — `docker run --env-file` passes quotes literally.
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/elysia_db

# Used by docker-compose.yml to provision the postgres container.
# Keep these in sync with DATABASE_URL.
POSTGRES_DB=elysia_db
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres

CLICKHOUSE_HOST=http://localhost:8123
CLICKHOUSE_USER=app
CLICKHOUSE_PASSWORD=secret
CLICKHOUSE_DATABASE=app

CLIENT_URL=http://localhost:3000

REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=password123
REDIS_DB=0

MAIL_HOST=
MAIL_PORT=
MAIL_SECURE=
MAIL_USER=
MAIL_PASS=
MAIL_FROM=
LOG_LEVEL=info

ALLOWED_HOST=*
